# ---------------------------------------------------------------------------
# Mug & Bean environment variables
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# git-ignored and must NEVER be committed. Variables prefixed with
# NEXT_PUBLIC_ are exposed to the browser — keep secrets out of those.
# ---------------------------------------------------------------------------

# --- Supabase ---------------------------------------
# Project URL and anon (public) key are safe for the browser.
# Local stack defaults (printed by `npm run db:start`):
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from `npx supabase status`>
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is SERVER-ONLY. Bypasses Row Level Security — never expose
# it to the client and never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# OAuth provider credentials for the LOCAL Supabase stack (config.toml reads
# these via env() substitution). Leave blank unless testing OAuth locally; on
# hosted projects these are configured in the Supabase dashboard instead.
# See docs/auth-setup.md for how to obtain them.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
SUPABASE_AUTH_EXTERNAL_APPLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# --- Google Cloud Vision OCR ------------------------
# Either provide an API key, or point to a service-account JSON credentials
# file via GOOGLE_APPLICATION_CREDENTIALS. Server-only. Both the OCR benchmark
# (npm run benchmark:ocr) and the live scan endpoint (POST /api/scan) use the
# API key via the Vision REST endpoint; without it /api/scan returns 503.
GOOGLE_CLOUD_VISION_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# --- AWS Textract OCR (benchmark alternative) -----------------------------
# The benchmarked alternative to Google Cloud Vision. Standard AWS credential
# chain; the runner skips Textract if these are absent. Requires the optional
# dev dependency: npm i -D @aws-sdk/client-textract. Server-only.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Transactional email (optional) ---------------------------------------
# Powers the waitlist welcome email. Leave RESEND_API_KEY blank to disable it
# entirely — the capture endpoint then skips sending (sign-ups still persist).
# WAITLIST_FROM_EMAIL must be a Resend-verified sender; it has a default.
RESEND_API_KEY=
WAITLIST_FROM_EMAIL=

# --- Analytics (optional) -------------------------------------------------
# Plausible Analytics (privacy-first, cookie-free). Set this to the domain
# registered in Plausible (e.g. mug-and-bean.vercel.app) to load the script and
# start counting page views + conversion events (cta_click, waitlist_submit).
# Leave blank to disable analytics entirely — no script loads and event calls
# become safe no-ops.
NEXT_PUBLIC_ANALYTICS_DOMAIN=

# --- App config -----------------------------------------------------------
# Public base URL of the deployment (used for OG tags, OAuth redirects, etc.).
NEXT_PUBLIC_SITE_URL=http://localhost:8000
